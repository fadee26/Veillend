# Example environment variables for veilend-mobile
# Copy this file to `.env` and fill values as needed for your environment.

# Backend API endpoints
API_URL_WEB=http://localhost:3000
API_URL_MOBILE=http://10.0.2.2:3000

# Stellar network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Feature toggles
USE_MOCKS=true
ENABLE_SECURE_STORE=false

# App environment
APP_ENV=development

# Optional integrations (leave blank in public repos)
ANALYTICS_KEY=
SENTRY_DSN=
